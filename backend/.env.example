# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/accident_detection

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Allowed domains for registration
# USER allowed email domains (comma separated)
USER_ALLOWED_DOMAINS=gmail.com,yahoo.com,outlook.com
# Leave empty to allow ALL domains for users

# GOV allowed email domains (only these can register as gov)
GOV_ALLOWED_DOMAINS=gov.in,nic.in,police.gov.in,mha.gov.in

# Frontend URLs
USER_FRONTEND_URL=http://localhost:3000
GOV_FRONTEND_URL=http://localhost:3001

# API Key (for Person 1 - AI system)
AI_API_KEY=supersecretkey123

# File uploads
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/screenshots

# ── TWILIO ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── MAPPLS ───────────────────────────────────────────────
MAPPLS_CLIENT_ID=
MAPPLS_CLIENT_SECRET=
MAPPLS_API_TOKEN = 
# ── EMERGENCY NUMBERS ────────────────────────────────────
POLICE_NUMBER=
AMBULANCE_NUMBER=

# ── CAMERA LOCATION ──────────────────────────────────────
CAMERA_LATITUDE=19.0760
CAMERA_LONGITUDE=72.8777

# ── For webcam only ──────────────────────────────────
VIDEO_SOURCES=0

# ── For video file only ──────────────────────────────
VIDEO_SOURCES=test_video.mp4

# ── For BOTH simultaneously ──────────────────────────
VIDEO_SOURCES=0,test_video.mp4

# ── Backend connection ───────────────────────────────
BACKEND_URL=http://localhost:5000/api/accidents
BACKEND_API_KEY=supersecretkey123
CONFIDENCE_THRESHOLD=0.45
FRAME_SKIP=2
FRAME_DELAY_MS=33
CAMERA_LATITUDE=19.0760
CAMERA_LONGITUDE=72.8777
ENVIRONMENT=development
MODEL_PATH=models/yolo11n.pt
ALERT_COOLDOWN_SECONDS=10
MAX_RETRIES=3