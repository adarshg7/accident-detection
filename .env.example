# ── BACKEND SETTINGS ──────────────────────────────────────
# URL where accident alerts are sent (FastAPI backend)
BACKEND_URL=http://localhost:5000/api/accident

# WebSocket URL for real-time dashboard updates
BACKEND_WS_URL=ws://localhost:5000/ws/live

# API Key for backend authentication (if required)
BACKEND_API_KEY=your_api_key_here

# ── VIDEO SETTINGS ────────────────────────────────────────
# Comma-separated sources: "0" for webcam, "path/to/video.mp4" for files
# Example: VIDEO_SOURCES="0,road_video.mp4"
VIDEO_SOURCES="0"

# ── AI MODEL SETTINGS ─────────────────────────────────────
# Path to the YOLOv11 model file
MODEL_PATH=models/yolo11n.pt

# Probability threshold (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.55

# Intersection-over-Union threshold (0.0 to 1.0)
IOU_THRESHOLD=0.45

# ── FRAME PROCESSING ─────────────────────────────────────
# Skip every N frames (higher = faster, lower = more accurate)
FRAME_SKIP=2

# Number of previous frames to keep for context/screenshots
FRAME_BUFFER_SIZE=150

# Delay between frames in milliseconds (0 = max speed, 33 = 30fps)
FRAME_DELAY_MS=33

# ── ALERTS ───────────────────────────────────────────────
# Wait N seconds before sending another alert for the same source
ALERT_COOLDOWN_SECONDS=10

# Max retries for failed HTTP requests
MAX_RETRIES=3

# Delay between retries in seconds
RETRY_DELAY_SECONDS=2.0

# ── STORAGE & LOGGING ─────────────────────────────────────
SCREENSHOT_DIR=screenshots
LOG_DIR=logs
LOG_LEVEL=INFO

# ── SYSTEM ──────────────────────────────────────────────
ENVIRONMENT=development
